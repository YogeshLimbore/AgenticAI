# ══════════════════════════════════════════════════
#  Naukri AI Agent v2 — Environment Variables
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# ── Naukri Login ──────────────────────────────────
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_naukri_password

# ── LLM — Gemini Free Tier ────────────────────────
# Get your FREE key at: https://aistudio.google.com/app/apikey
# Free quota: 15 req/min · 1,500 req/day · 1M tokens/day
# Model used: gemini-1.5-flash (fastest free model)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Job Search Settings ───────────────────────────
JOB_LOCATION=Pune
MAX_APPLY_PER_RUN=15
EXPERIENCE_YRS=0-2
MATCH_THRESHOLD=60

# ── Scheduler (optional) ──────────────────────────
# Set to run automatically every morning (24-hour format)
# Leave empty to disable auto-scheduling
SCHEDULE_TIME=09:00

# ── Telegram Notifications (optional, 100% free) ──
# Create a bot: message @BotFather on Telegram → /newbot
# Get your chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Security ──────────────────────────────────────
# Set to "keyring" to store password in OS keyring (more secure)
# Set to "env" to use plain .env (default, fine for personal use)
CREDENTIAL_STORE=env
